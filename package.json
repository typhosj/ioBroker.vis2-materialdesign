{
  "name": "iobroker.vis2-materialdesign",
  "version": "0.2.0",
  "description": "Native VIS 2 Material Design widgets based on the original work by Scrounger",
  "author": {
    "name": "typhosj",
    "email": "typhosj@gmx.de"
  },
  "homepage": "https://github.com/typhosj/ioBroker.vis2-materialdesign",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "admin/**/*.css",
    "admin/**/*.d.ts",
    "admin/**/*.html",
    "admin/**/*.js",
    "admin/**/*.json",
    "admin/**/*.mp3",
    "admin/**/*.png",
    "admin/**/*.woff2",
    "widgets/**/*.css",
    "widgets/**/*.html",
    "widgets/**/*.jpg",
    "widgets/**/*.js",
    "widgets/**/*.json",
    "widgets/**/*.mp3",
    "widgets/**/*.png",
    "widgets/**/*.woff2",
    "io-package.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ioBroker",
    "material",
    "GUI",
    "vis-2",
    "vis2-materialdesign"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/typhosj/ioBroker.vis2-materialdesign.git"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/jura": "^5.2.7",
    "@fontsource/roboto-condensed": "^5.2.8",
    "@iobroker/adapter-react-v5": "^8.2.13",
    "@iobroker/eslint-config": "^2.3.4",
    "@mdi/font": "6.7.96",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "chart.js": "^2.9.4",
    "chartjs-plugin-datalabels": "^0.7.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "main": "widgets/vis2-materialdesign/customWidgets.js",
  "scripts": {
    "test:package": "node test/package.js",
    "test:pr-gate": "node test/pr-gate.js",
    "test:widgets": "vitest run",
    "test": "npm run test:package && npm run test:widgets",
    "pr:repocheck": "node -e \"require('fs').rmSync('src-widgets-ts/build', { recursive: true, force: true })\" && npx @iobroker/repochecker https://github.com/typhosj/ioBroker.vis2-materialdesign --local",
    "pr:check": "npm run build && npm run lint && npm test && npm run test:pr-gate && npm pack --dry-run && npm run pr:repocheck",
    "release": "release-script",
    "lint": "eslint src-widgets-ts/src src-admin/src",
    "build": "node tasks",
    "build:admin": "vite build --config vite.admin.config.mjs"
  },
  "bugs": {
    "url": "https://github.com/typhosj/ioBroker.vis2-materialdesign/issues"
  },
  "readmeFilename": "README.md",
  "dependencies": {
    "axios": "^1.18.1",
    "chroma-js": "^3.2.0",
    "mathjs": "^15.2.0",
    "moment": "^2.30.1",
    "moment-duration-format": "^2.3.2"
  },
  "contributors": [
    "Scrounger <scrounger@gmx.net>"
  ]
}
