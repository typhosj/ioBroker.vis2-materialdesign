            "GUI",
            "vis2-materialdesign"
        ],
        "platform": "Javascript/Node.js",
        "icon": "vis-materialdesign.png",
        "enabled": true,
        "extIcon": "https://raw.githubusercontent.com/typhosj/ioBroker.vis2-materialdesign/master/admin/vis-materialdesign.png",
        "readme": "https://github.com/typhosj/ioBroker.vis2-materialdesign/blob/master/README.md",
        "loglevel": "info",
        "restartAdapters": [
            "vis-2"
        ],
        "onlyWWW": true,
        "singleton": true,
        "type": "visualization-widgets",
        "mode": "none",
        "connectionType": "local",
        "dataSource": "push",
        "tier": 3,
        "licenseInformation": {
            "license": "MIT",
            "type": "free",
            "link": "https://opensource.org/license/mit"
        },
        "localLinks": {
            "_default": "%web_protocol%://%ip%:%web_port%/vis-2/edit.html"
        },
        "adminUI": {
            "config": "materialize"
        },
        "globalDependencies": [
            {
                "admin": ">=7.6.20"
            }
        ],
        "dependencies": [],
        "visWidgets": {
            "vis2MaterialDesignWidgets": {
                "i18n": "component",
                "name": "vis2MaterialDesignWidgets",
                "url": "vis2-materialdesign/customWidgets.js",
                "bundlerType": "module",
                "components": [
                    "MaterialDesignButtonNavigationVertical",
                    "MaterialDesignButtonLinkVertical",
                    "MaterialDesignButtonStateVertical",
                    "MaterialDesignButtonStateMultiVertical",
                    "MaterialDesignButtonAditionVertical",
                    "MaterialDesignButtonToggleVertical",
                    "MaterialDesignButtonNavigation",
                    "MaterialDesignButtonLink",
                    "MaterialDesignButtonState",
                    "MaterialDesignButtonStateMulti",
                    "MaterialDesignButtonAdition",
                    "MaterialDesignButtonToggle",
                    "MaterialDesignIconButtonNavigation",
                    "MaterialDesignIconButtonLink",
                    "MaterialDesignIconButtonState",
                    "MaterialDesignIconButtonStateMulti",
                    "MaterialDesignIconButtonAdition",
                    "MaterialDesignIconButtonToggle",
                    "MaterialDesignIconButtonSlider",
                    "MaterialDesignCheckbox",
                    "MaterialDesignIcon",
                    "MaterialDesignSwitch",
                    "MaterialDesignValue"
                ]
            }
        }
    },
    "native": {
        "scriptName": "Theme",
        "variableName": "myMdwTheme",
        "javascriptInstance": "",
        "sentryReport": false,
        "colors": [],
        "defaultcolors": [],
        "colorsDark": [],
        "defaultcolorsDark": [],
        "fonts": [],
        "defaultfonts": [],
        "fontSizes": [],
        "defaultfontSizes": [],
        "dependencies": [
            "basic"
        ]
    },
    "objects": [],
    "instanceObjects": [
        {
            "_id": "colors.darkTheme",
            "type": "state",
            "common": {
                "role": "switch",
                "name": "Switch between light and dark colors",
                "type": "boolean",
                "read": true,
                "write": true,
                "def": false
            },
            "native": {}
        },
        {
            "_id": "sentry",
            "type": "state",
            "common": {
                "role": "switch",
                "name": "send Widget error reports",
                "desc": "Sentry - automatic error reporting",
                "type": "boolean",
                "read": true,
                "write": true,
                "def": false
            },
            "native": {}
        },
        {
            "_id": "lastchange",
            "type": "state",
            "common": {
                "role": "value",
                "name": "last theme changes",
                "desc": "last theme changes",
                "type": "number",
                "read": true,
                "write": false,
                "def": 0
            },
            "native": {}
        }
    ]
}
